---
import { footerGroups, githubUrl } from "../data/site-navigation";
import BrandMark from "./BrandMark.astro";
---

<footer class="site-footer">
	<div class="container site-footer__inner">
		<div class="site-footer__brand">
			<a class="wordmark" href="/" aria-label="Hevy MCP home">
				<BrandMark />
				<span>hevy <span class="wordmark__mcp">mcp</span></span>
			</a>
			<p>Independent, open source, and built to turn training data into useful answers.</p>
		</div>
		<nav class="site-footer__groups" aria-label="Footer navigation">
			{footerGroups.map((group) => (
				<div class="site-footer__group">
					<h2>{group.label}</h2>
					<ul>
						{group.links.map((link) => (
							<li><a href={link.href} data-github-link={link.href === githubUrl ? true : undefined} data-placement={link.href === githubUrl ? "footer" : undefined}>{link.label}</a></li>
						))}
					</ul>
				</div>
			))}
		</nav>
	</div>
	<div class="container site-footer__legal">
		<p>Hevy MCP is an independent open-source project and is not affiliated with or endorsed by Hevy.</p>
		<p>© {new Date().getFullYear()} Hevy MCP contributors.</p>
	</div>
</footer>
