---
import BrandMark from "./BrandMark.astro";
---

<header class="site-header" data-site-header>
	<div class="container site-header__inner">
		<a class="wordmark" href="#top" aria-label="Hevy MCP home">
			<BrandMark />
			<span>hevy <span class="wordmark__mcp">mcp</span></span>
		</a>

		<button
			class="mobile-menu-button"
			type="button"
			aria-expanded="false"
			aria-controls="site-navigation"
			data-menu-toggle
		>
			<span class="sr-only">Toggle navigation</span>
			<span></span><span></span>
		</button>

		<nav class="site-nav" id="site-navigation" aria-label="Main navigation" data-site-nav>
			<a href="#features">Features</a>
			<a href="#demo">Demo</a>
			<a href="#setup">Setup</a>
			<a href="#faq">FAQ</a>
			<a
				class="site-nav__github"
				href="https://github.com/chrisdoc/hevy-mcp"
				aria-label="View Hevy MCP on GitHub"
				title="View on GitHub"
			>
				<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
					<path d="M12 .3a12 12 0 0 0-3.79 23.39c.6.11.82-.26.82-.58v-2.04c-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.33-1.76-1.33-1.76-1.09-.75.08-.74.08-.74 1.2.09 1.83 1.23 1.83 1.23 1.07 1.83 2.8 1.3 3.48.99.11-.77.42-1.3.76-1.6-2.66-.3-5.46-1.33-5.46-5.93 0-1.31.47-2.38 1.23-3.22-.12-.3-.53-1.52.12-3.17 0 0 1-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.3-1.55 3.3-1.23 3.3-1.23.65 1.65.24 2.87.12 3.17.77.84 1.23 1.91 1.23 3.22 0 4.61-2.8 5.62-5.47 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.22.69.83.57A12 12 0 0 0 12 .3Z" />
				</svg>
				<span class="sr-only">GitHub</span>
			</a>
			<a class="button button--small button--ink" href="#setup" data-setup-mode="oauth">Connect Hevy</a>
		</nav>
	</div>
</header>

<script>
	const header = document.querySelector<HTMLElement>("[data-site-header]");
	const toggle = document.querySelector<HTMLButtonElement>("[data-menu-toggle]");
	const nav = document.querySelector<HTMLElement>("[data-site-nav]");

	if (header && toggle && nav) {
		header.dataset.enhanced = "true";
		toggle.addEventListener("click", () => {
			const open = toggle.getAttribute("aria-expanded") === "true";
			toggle.setAttribute("aria-expanded", String(!open));
			nav.toggleAttribute("data-open", !open);
		});

		nav.querySelectorAll("a").forEach((link) => {
			link.addEventListener("click", () => {
				toggle.setAttribute("aria-expanded", "false");
				nav.removeAttribute("data-open");
			});
		});
	}
</script>
