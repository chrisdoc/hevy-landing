---
import { transportModes } from "../data/setup";
---

<section class="architecture section" id="how-it-works" aria-labelledby="architecture-title">
	<div class="container architecture__layout">
		<div class="architecture__copy">
			<p class="context-line context-line--light">How it works</p>
			<h2 id="architecture-title">Same tools.<br />Two ways in.</h2>
			<p>
				Choose the transport that fits your client. The tool contract stays the same; only the
				path to Hevy changes.
			</p>
		</div>

		<div class="architecture__instrument" data-architecture>
			<div class="architecture__tabs" role="tablist" aria-label="Architecture transport">
				{transportModes.map((mode, index) => (
					<button
						id={`architecture-tab-${mode.id}`}
						type="button"
						role="tab"
						aria-controls={`architecture-panel-${mode.id}`}
						aria-selected={index === 0 ? "true" : "false"}
						tabindex={index === 0 ? 0 : -1}
						data-architecture-tab={mode.id}
					>
						{mode.shortLabel}
					</button>
				))}
			</div>

			{transportModes.map((mode) => (
				<div
					id={`architecture-panel-${mode.id}`}
					class="architecture__panel"
					role="tabpanel"
					aria-labelledby={`architecture-tab-${mode.id}`}
					data-architecture-panel={mode.id}
				>
					<div class="route" aria-label={`${mode.label} route`}>
						{mode.route.map((step, index) => (
							<>
								<div class:list={["route__step", index === 2 && "route__step--active"]}>
									<span>{String(index + 1).padStart(2, "0")}</span>
									<strong>{step}</strong>
								</div>
								{index < mode.route.length - 1 && <span class="route__arrow" aria-hidden="true">→</span>}
							</>
						))}
					</div>
				</div>
			))}

			<ul class="trust-list">
				<li>Hosted bearer credentials are validated per request and are not persisted.</li>
				<li>Local stdio receives the key through the client’s child-process environment.</li>
				<li>Read tools retrieve data. Create and update tools run only when called.</li>
			</ul>
		</div>
	</div>
</section>

<script>
	import { bindTabs } from "../scripts/tabs";

	const architecture = document.querySelector<HTMLElement>("[data-architecture]");

	if (architecture) {
		architecture.dataset.enhanced = "true";
		bindTabs({
			root: architecture,
			tabSelector: "[data-architecture-tab]",
			panelSelector: "[data-architecture-panel]",
			tabId: (tab) => tab.dataset.architectureTab,
			panelId: (panel) => panel.dataset.architecturePanel,
			initialId: "https",
		});
	}
</script>
