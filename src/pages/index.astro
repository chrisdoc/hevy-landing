---
import Capabilities from "../components/Capabilities.astro";
import DemoSection from "../components/DemoSection.astro";
import FaqSection from "../components/FaqSection.astro";
import HeroChat from "../components/HeroChat.astro";
import ProblemSection from "../components/ProblemSection.astro";
import SetupGuide from "../components/SetupGuide.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { toolCount } from "../data/setup";
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Hevy MCP — Talk to your Hevy data from your AI assistant";
const description =
	"Connect Hevy workouts, routines, exercises, and measurements to Claude, Cursor, Codex, and other MCP clients.";

---

<BaseLayout {title} {description}>
	<div id="top"></div>
	<SiteHeader />
	<main id="main-content">
		<section class="hero section" aria-labelledby="hero-title">
			<div class="container hero__layout">
				<div class="hero__copy">
					<p class="context-line">Connect Hevy to the AI assistant you already use</p>
					<h1 id="hero-title">Talk to your <span>Hevy data</span> from your AI assistant.</h1>
					<p class="hero__lead">
						Hevy MCP is the connector that lets Claude, Cursor, Codex, and other AI assistants use your
						workouts, routines, exercise history, and measurements. Analyze progress, find what you need,
						and log changes in plain language.
					</p>
					<div class="hero__actions">
						<a class="button button--ink" href="#setup" data-setup-mode="oauth">Connect Hevy in my browser <span aria-hidden="true">→</span></a>
						<a class="button button--outline" href="#setup" data-setup-mode="stdio">Run Hevy MCP locally</a>
					</div>
					<div class="hero__meta">
						<a class="text-link" href="https://github.com/chrisdoc/hevy-mcp">View source on GitHub <span aria-hidden="true">↗</span></a>
						<span>Hevy PRO API access is required.</span>
					</div>
					<div class="hero__proof" aria-label="Project facts">
						<span>{toolCount} focused tools</span><span>3 connection methods</span><span>18-second demo</span><span>MIT licensed open source</span>
					</div>
				</div>

				<div class="hero__visual">
					<HeroChat />
				</div>
			</div>
		</section>

		<ProblemSection />
		<Capabilities />
		<DemoSection />
		<SetupGuide />
		<FaqSection />

		<section class="final-cta section" aria-labelledby="final-cta-title">
			<div class="container final-cta__layout">
				<div>
					<p class="context-line">Start with one useful question</p>
					<h2 id="final-cta-title">Put your Hevy data to work.</h2>
					<p>
						Connect in the browser for the shortest path—no local install required. Prefer local control?
						Run the same open-source server on your machine. Hevy PRO API access is required.
						Inspect the source on GitHub and choose the connection method that fits your workflow.
					</p>
				</div>
				<div class="final-cta__actions">
					<a class="button button--yellow" href="#setup" data-setup-mode="oauth">Connect Hevy in my browser <span aria-hidden="true">→</span></a>
					<a class="button button--light-outline" href="#setup" data-setup-mode="stdio">Run Hevy MCP locally</a>
					<a class="text-link text-link--light" href="https://github.com/chrisdoc/hevy-mcp">Explore the open-source project <span aria-hidden="true">↗</span></a>
				</div>
			</div>
		</section>
	</main>
	<SiteFooter />
</BaseLayout>
