---
import Capabilities from "../components/Capabilities.astro";
import DemoSection from "../components/DemoSection.astro";
import FaqSection from "../components/FaqSection.astro";
import HeroChat from "../components/HeroChat.astro";
import MobileSetupCta from "../components/MobileSetupCta.astro";
import SecuritySummary from "../components/SecuritySummary.astro";
import SetupOverview from "../components/SetupOverview.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { toolCount } from "../data/setup";
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Hevy MCP — Ask your AI assistant what changed in your training";
const description = "Connect Claude, Codex, Cursor, and other MCP clients to Hevy to understand progress, find routines, and log training changes.";
---

<BaseLayout {title} {description} canonicalPath="/" includeSoftwareSchema>
	<div id="top"></div>
	<SiteHeader />
	<main id="main-content">
		<section class="hero section" data-hero aria-labelledby="hero-title">
			<div class="container hero__layout">
				<div class="hero__copy">
					<p class="context-line">Connect Hevy to the AI assistant you already use</p>
					<h1 id="hero-title">Ask your AI assistant what changed in your training.</h1>
					<p class="hero__lead">Hevy MCP connects Claude, Codex, Cursor, and other MCP clients to your Hevy history—so you can understand progress, find routines, and log changes without digging through workouts.</p>
					<div class="hero__actions">
						<a class="button button--yellow" href="/docs/connect/browser/" data-setup-cta data-placement="hero" data-method-id="oauth">Start browser setup <span aria-hidden="true">→</span></a>
						<a class="button button--outline" href="/docs/connect/local/" data-setup-cta data-placement="hero" data-method-id="stdio">Set up local mode</a>
						<a class="text-link" href="#demo" data-demo-link>Watch the 18-second demo <span aria-hidden="true">↓</span></a>
					</div>
					<div class="hero__activation">
						<strong>Connect Hevy, then ask: “Which Hevy account is connected?”</strong>
						<span>Free and open source · No local install for browser sign-in · Hevy PRO required for API access</span>
						<span>Independent project. Not affiliated with or endorsed by Hevy.</span>
						<a class="text-link" href="/security/">See how your key is handled <span aria-hidden="true">→</span></a>
					</div>
					<div class="hero__meta">
						<a class="text-link" href="https://github.com/chrisdoc/hevy-mcp" data-github-link data-placement="hero">View source on GitHub <span aria-hidden="true">↗</span></a>
					</div>
					<div class="hero__proof" aria-label="Project facts">
						<span>{toolCount} focused tools</span><span>3 connection methods</span><span>18-second demo</span><span>MIT licensed</span>
					</div>
				</div>

				<div class="hero__visual">
					<HeroChat />
				</div>
			</div>
		</section>

		<Capabilities />
		<DemoSection />
		<SetupOverview />
		<SecuritySummary />
		<FaqSection />

		<section class="final-cta section" data-final-cta aria-labelledby="final-cta-title">
			<div class="container final-cta__layout">
				<div>
					<p class="context-line context-line--light">Start with one useful question</p>
					<h2 id="final-cta-title">Your workout history already contains the answers.</h2>
					<p>Connect with browser sign-in, then ask which Hevy account is connected. Hevy MCP is free and open source; Hevy PRO is required for API access.</p>
				</div>
				<div class="final-cta__actions">
					<a class="button button--yellow" href="/docs/connect/browser/" data-setup-cta data-placement="final" data-method-id="oauth">Start browser setup <span aria-hidden="true">→</span></a>
					<a class="button button--light-outline" href="/docs/connect/local/" data-setup-cta data-placement="final" data-method-id="stdio">Set up local mode</a>
					<a class="text-link text-link--light" href="https://github.com/chrisdoc/hevy-mcp" data-github-link data-placement="hero">Explore the open-source project <span aria-hidden="true">↗</span></a>
				</div>
			</div>
		</section>
	</main>
	<MobileSetupCta />
	<SiteFooter />
</BaseLayout>
